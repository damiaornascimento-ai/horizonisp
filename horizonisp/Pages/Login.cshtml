@page
@model LoginModel
@{
    ViewData["Title"] = "Entrar";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Horizon ISP</title>
    <partial name="_ThemeHead" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">
    <div class="login-page-shell">
        <div class="login-page-overlay" aria-hidden="true"></div>
        <div class="login-page-content">
            <div class="container">
                <div class="row justify-content-center align-items-center min-vh-100">
                    <div class="col-md-5">
                        <div class="card shadow-sm">
                            <div class="card-body p-4">
                                <h1 class="h3 mb-1 text-center">Horizon ISP</h1>
                                <p class="text-muted text-center mb-4">Entre com sua conta de administrador ou de cliente.</p>

                                @if (!string.IsNullOrEmpty(Model.Erro))
                                {
                                    <div class="alert alert-danger">@Model.Erro</div>
                                }

                                <form method="post">
                                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                                    <div class="mb-3">
                                        <label asp-for="Input.Identificador" class="form-label"></label>
                                        <input asp-for="Input.Identificador" class="form-control" autocomplete="username" />
                                        <span asp-validation-for="Input.Identificador" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Input.Senha" class="form-label"></label>
                                        <input asp-for="Input.Senha" class="form-control" autocomplete="current-password" />
                                        <span asp-validation-for="Input.Senha" class="text-danger"></span>
                                    </div>
                                    <button type="submit" class="btn btn-primary w-100">Entrar</button>
                                </form>

                                <div class="text-center mt-3">
                                    <a asp-page="/Portal/EsqueciSenha" class="small">Esqueci minha senha</a>
                                </div>

                                <p class="text-muted small mt-4 mb-3 text-center">
                                    Admin: admin@horizonisp.local / admin123<br />
                                    Cliente: joao.silva@email.com / cliente123
                                </p>

                                <partial name="_ThemePickerInline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
