@page
@model IndexModel
@{
    ViewData["Title"] = "Painel";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h1 class="h3 mb-1">Painel</h1>
        <p class="text-muted mb-0">Visão geral do provedor</p>
    </div>
    <div class="card border-0 shadow-sm theme-picker-panel">
        <div class="card-body py-2 px-3 d-flex align-items-center gap-2">
            <span class="text-muted small fw-semibold text-nowrap">Cor do tema</span>
            <partial name="_ThemePickerInline" />
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <a asp-page="/Clientes/Index" class="text-decoration-none text-body d-block h-100">
            <div class="card border-0 shadow-sm h-100 card-dashboard-link">
                <div class="card-body">
                    <div class="text-muted small">Clientes</div>
                    <div class="display-6">@Model.Resumo.TotalClientes</div>
                    <div class="small text-success">@Model.Resumo.ClientesAtivos ativos</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Assinaturas/Index" class="text-decoration-none text-body d-block h-100">
            <div class="card border-0 shadow-sm h-100 card-dashboard-link">
                <div class="card-body">
                    <div class="text-muted small">Assinaturas ativas</div>
                    <div class="display-6">@Model.Resumo.AssinaturasAtivas</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Relatorios/Index" class="text-decoration-none text-body d-block h-100">
            <div class="card border-0 shadow-sm h-100 card-dashboard-link">
                <div class="card-body">
                    <div class="text-muted small">Receita do mês</div>
                    <div class="display-6">@EnumHelper.Moeda(Model.Resumo.ReceitaMesAtual)</div>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <a asp-page="/Faturas/Index" asp-route-status="@StatusFatura.Pendente" class="text-decoration-none text-body d-block h-100">
            <div class="card border-0 shadow-sm h-100 card-dashboard-link">
                <div class="card-body">
                    <h2 class="h5">Faturas pendentes</h2>
                    <p class="display-6 mb-0">@Model.Resumo.FaturasPendentes</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Relatorios/Index" asp-fragment="inadimplentes" class="text-decoration-none text-body d-block h-100">
            <div class="card border-0 shadow-sm h-100 card-dashboard-link">
                <div class="card-body">
                    <h2 class="h5">Faturas atrasadas</h2>
                    <p class="display-6 mb-0 text-danger">@Model.Resumo.FaturasAtrasadas</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Chamados/Index" class="text-decoration-none text-body d-block h-100">
            <div class="card border-0 shadow-sm h-100 card-dashboard-link">
                <div class="card-body">
                    <h2 class="h5">Chamados abertos</h2>
                    <p class="display-6 mb-0">@Model.Resumo.ChamadosAbertos</p>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h2 class="h5 mb-0">Clientes por conexão</h2>
                    <a asp-page="/Clientes/Index" class="small text-decoration-none">Ver todos</a>
                </div>
                <div class="row align-items-center">
                    <div class="col-sm-7">
                        <div class="chart-conexao-wrapper mx-auto">
                            <canvas id="chartConexaoClientes"></canvas>
                        </div>
                    </div>
                    <div class="col-sm-5 mt-3 mt-sm-0">
                        <div class="d-flex flex-column gap-3">
                            <a asp-page="/Clientes/Index" asp-route-categoria="@CategoriaConexaoCliente.Online"
                               class="text-decoration-none text-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span><span class="badge rounded-pill bg-success me-2">&nbsp;</span>Online</span>
                                    <strong class="text-success">@Model.Resumo.ClientesOnline</strong>
                                </div>
                            </a>
                            <a asp-page="/Clientes/Index" asp-route-categoria="@CategoriaConexaoCliente.Offline"
                               class="text-decoration-none text-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span><span class="badge rounded-pill bg-warning text-dark me-2">&nbsp;</span>Offline</span>
                                    <strong class="text-warning">@Model.Resumo.ClientesOffline</strong>
                                </div>
                            </a>
                            <a asp-page="/Clientes/Index" asp-route-categoria="@CategoriaConexaoCliente.Bloqueado"
                               class="text-decoration-none text-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span><span class="badge rounded-pill bg-danger me-2">&nbsp;</span>Bloqueados</span>
                                    <strong class="text-danger">@Model.Resumo.ClientesBloqueados</strong>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-md-4">
        <a asp-page="/Rede/Index" class="text-decoration-none text-body d-block h-100">
            <div class="card border-0 shadow-sm h-100 card-dashboard-link">
                <div class="card-body">
                    <h2 class="h5">ONUs offline</h2>
                    <p class="display-6 mb-0 @(Model.Resumo.OnusOffline > 0 ? "text-warning" : "")">@Model.Resumo.OnusOffline</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/OrdensServico/Index" class="text-decoration-none text-body d-block h-100">
            <div class="card border-0 shadow-sm h-100 card-dashboard-link">
                <div class="card-body">
                    <h2 class="h5">O.S. em aberto</h2>
                    <p class="display-6 mb-0">@Model.Resumo.OrdensServicoAbertas</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Nfse/Index" class="text-decoration-none text-body d-block h-100">
            <div class="card border-0 shadow-sm h-100 card-dashboard-link">
                <div class="card-body">
                    <h2 class="h5">NFS-e emitidas</h2>
                    <p class="display-6 mb-0">@Model.Resumo.TotalNfse</p>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="mt-4">
    <a class="btn btn-outline-primary me-2" asp-page="/Clientes/Create">Novo cliente</a>
    <a class="btn btn-outline-primary me-2" asp-page="/Assinaturas/Create">Nova assinatura</a>
    <a class="btn btn-outline-primary" asp-page="/Faturas/Index">Ver faturas</a>
    <a class="btn btn-outline-secondary" asp-page="/Faturamento/Index">Faturamento</a>
    <a class="btn btn-outline-secondary" asp-page="/Nfse/Index">NFS-e</a>
    <a class="btn btn-outline-secondary" asp-page="/Relatorios/Index">Relatórios</a>
    <a class="btn btn-outline-secondary" asp-page="/Rede/Index">Rede FTTH</a>
    <a class="btn btn-outline-secondary" asp-page="/Chamados/Index">Chamados</a>
    <a class="btn btn-outline-secondary" asp-page="/OrdensServico/Index">O.S.</a>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            const canvas = document.getElementById('chartConexaoClientes');
            if (!canvas) return;

            const valores = [
                @Model.Resumo.ClientesOnline,
                @Model.Resumo.ClientesOffline,
                @Model.Resumo.ClientesBloqueados
            ];

            if (valores.every(v => v === 0)) {
                canvas.parentElement.innerHTML =
                    '<p class="text-muted text-center mb-0 py-4">Nenhum cliente cadastrado.</p>';
                return;
            }

            new Chart(canvas, {
                type: 'doughnut',
                data: {
                    labels: ['Online', 'Offline', 'Bloqueados'],
                    datasets: [{
                        data: valores,
                        backgroundColor: ['#198754', '#ffc107', '#dc3545'],
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '60%',
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function (ctx) {
                                    const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                                    const pct = total ? Math.round((ctx.raw / total) * 100) : 0;
                                    return ctx.label + ': ' + ctx.raw + ' (' + pct + '%)';
                                }
                            }
                        }
                    }
                }
            });
        })();
    </script>
}
