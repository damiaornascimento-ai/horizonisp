@page
@model IndexModel
@{
    ViewData["Title"] = "Painel";
}

<nav class="mk-tabs" aria-label="Workspace">
    <span class="mk-tab active">Indicadores</span>
    <a class="mk-tab" asp-page="/Chamados/Index">Atendimentos</a>
    <a class="mk-tab" asp-page="/OrdensServico/Index">Ordens de serviço</a>
    <a class="mk-tab" asp-page="/Clientes/Index">Clientes</a>
</nav>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <a asp-page="/Clientes/Index" class="text-decoration-none d-block h-100">
            <div class="mk-kpi-card">
                <span class="mk-kpi-icon"><i class="bi bi-people-fill"></i></span>
                <div class="mk-kpi-label">Clientes</div>
                <div class="mk-kpi-value">@Model.Resumo.TotalClientes</div>
                <div class="mk-kpi-meta text-success">@Model.Resumo.ClientesAtivos ativos</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Assinaturas/Index" class="text-decoration-none d-block h-100">
            <div class="mk-kpi-card accent">
                <span class="mk-kpi-icon"><i class="bi bi-wifi"></i></span>
                <div class="mk-kpi-label">Assinaturas ativas</div>
                <div class="mk-kpi-value">@Model.Resumo.AssinaturasAtivas</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Relatorios/Index" class="text-decoration-none d-block h-100">
            <div class="mk-kpi-card success">
                <span class="mk-kpi-icon"><i class="bi bi-currency-dollar"></i></span>
                <div class="mk-kpi-label">Receita do mês</div>
                <div class="mk-kpi-value">@EnumHelper.Moeda(Model.Resumo.ReceitaMesAtual)</div>
            </div>
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <a asp-page="/Faturas/Index" asp-route-status="@StatusFatura.Pendente" class="text-decoration-none d-block h-100">
            <div class="mk-kpi-card">
                <span class="mk-kpi-icon"><i class="bi bi-receipt"></i></span>
                <div class="mk-kpi-label">Faturas pendentes</div>
                <div class="mk-kpi-value">@Model.Resumo.FaturasPendentes</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Relatorios/Index" asp-fragment="inadimplentes" class="text-decoration-none d-block h-100">
            <div class="mk-kpi-card danger">
                <span class="mk-kpi-icon"><i class="bi bi-exclamation-triangle-fill"></i></span>
                <div class="mk-kpi-label">Faturas atrasadas</div>
                <div class="mk-kpi-value text-danger">@Model.Resumo.FaturasAtrasadas</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Chamados/Index" class="text-decoration-none d-block h-100">
            <div class="mk-kpi-card warning">
                <span class="mk-kpi-icon"><i class="bi bi-headset"></i></span>
                <div class="mk-kpi-label">Atendimentos abertos</div>
                <div class="mk-kpi-value">@Model.Resumo.ChamadosAbertos</div>
            </div>
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <a asp-page="/Rede/Index" class="text-decoration-none d-block h-100">
            <div class="mk-kpi-card warning">
                <span class="mk-kpi-icon"><i class="bi bi-hdd-network-fill"></i></span>
                <div class="mk-kpi-label">ONUs offline</div>
                <div class="mk-kpi-value @(Model.Resumo.OnusOffline > 0 ? "text-warning" : "")">@Model.Resumo.OnusOffline</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/OrdensServico/Index" class="text-decoration-none d-block h-100">
            <div class="mk-kpi-card">
                <span class="mk-kpi-icon"><i class="bi bi-tools"></i></span>
                <div class="mk-kpi-label">O.S. em aberto</div>
                <div class="mk-kpi-value">@Model.Resumo.OrdensServicoAbertas</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Nfse/Index" class="text-decoration-none d-block h-100">
            <div class="mk-kpi-card accent">
                <span class="mk-kpi-icon"><i class="bi bi-file-earmark-text"></i></span>
                <div class="mk-kpi-label">NFS-e emitidas</div>
                <div class="mk-kpi-value">@Model.Resumo.TotalNfse</div>
            </div>
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="mk-panel h-100">
            <div class="mk-panel-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-pie-chart me-2"></i>Clientes por conexão</span>
                <a asp-page="/Clientes/Index" class="small text-decoration-none">Ver todos</a>
            </div>
            <div class="mk-panel-body">
                <div class="row align-items-center">
                    <div class="col-sm-7">
                        <div class="chart-conexao-wrapper mx-auto">
                            <canvas id="chartConexaoClientes"></canvas>
                        </div>
                    </div>
                    <div class="col-sm-5 mt-3 mt-sm-0">
                        <div class="d-flex flex-column gap-3">
                            <a asp-page="/Clientes/Index" asp-route-categoria="@CategoriaConexaoCliente.Online"
                               class="text-decoration-none text-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span><span class="badge rounded-pill bg-success me-2">&nbsp;</span>Online</span>
                                    <strong class="text-success">@Model.Resumo.ClientesOnline</strong>
                                </div>
                            </a>
                            <a asp-page="/Clientes/Index" asp-route-categoria="@CategoriaConexaoCliente.Offline"
                               class="text-decoration-none text-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span><span class="badge rounded-pill bg-warning text-dark me-2">&nbsp;</span>Offline</span>
                                    <strong class="text-warning">@Model.Resumo.ClientesOffline</strong>
                                </div>
                            </a>
                            <a asp-page="/Clientes/Index" asp-route-categoria="@CategoriaConexaoCliente.Bloqueado"
                               class="text-decoration-none text-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span><span class="badge rounded-pill bg-danger me-2">&nbsp;</span>Bloqueados</span>
                                    <strong class="text-danger">@Model.Resumo.ClientesBloqueados</strong>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mk-quick-actions">
    <span class="text-muted small fw-semibold me-2 align-self-center">Ações rápidas:</span>
    <a class="btn btn-primary btn-sm" asp-page="/Clientes/Create"><i class="bi bi-person-plus me-1"></i>Novo cliente</a>
    <a class="btn btn-outline-primary btn-sm" asp-page="/Assinaturas/Create"><i class="bi bi-wifi me-1"></i>Nova assinatura</a>
    <a class="btn btn-outline-primary btn-sm" asp-page="/Faturas/Index"><i class="bi bi-receipt me-1"></i>Faturas</a>
    <a class="btn btn-outline-secondary btn-sm" asp-page="/Faturamento/Index">Faturamento</a>
    <a class="btn btn-outline-secondary btn-sm" asp-page="/Chamados/Index">Atendimentos</a>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            const canvas = document.getElementById('chartConexaoClientes');
            if (!canvas) return;

            const valores = [
                @Model.Resumo.ClientesOnline,
                @Model.Resumo.ClientesOffline,
                @Model.Resumo.ClientesBloqueados
            ];

            if (valores.every(v => v === 0)) {
                canvas.parentElement.innerHTML =
                    '<p class="text-muted text-center mb-0 py-4">Nenhum cliente cadastrado.</p>';
                return;
            }

            new Chart(canvas, {
                type: 'doughnut',
                data: {
                    labels: ['Online', 'Offline', 'Bloqueados'],
                    datasets: [{
                        data: valores,
                        backgroundColor: ['#0069b4', '#00a8e8', '#dc3545'],
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '60%',
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function (ctx) {
                                    const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                                    const pct = total ? Math.round((ctx.raw / total) * 100) : 0;
                                    return ctx.label + ': ' + ctx.raw + ' (' + pct + '%)';
                                }
                            }
                        }
                    }
                }
            });
        })();
    </script>
}
