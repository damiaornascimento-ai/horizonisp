@page
@model horizonisp.Pages.Assinaturas.CreateModel
@{
    ViewData["Title"] = "Nova assinatura";
}

<h1 class="h3 mb-4">Nova assinatura</h1>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <partial name="_Form" model="Model.Assinatura" />
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
