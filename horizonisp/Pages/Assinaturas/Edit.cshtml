@page "{id:int}"
@model horizonisp.Pages.Assinaturas.EditModel
@{
    ViewData["Title"] = "Editar assinatura";
}

<h1 class="h3 mb-4">Editar assinatura</h1>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Assinatura.Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <partial name="_Form" model="Model.Assinatura" />
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
