<div class="theme-picker-inline" role="group" aria-label="Cor do tema">
    <span class="theme-picker-label text-muted small">Cor:</span>
    <button type="button" class="theme-swatch-btn theme-option" data-theme="azul" title="Azul"
            style="background-color: #0d6efd;"></button>
    <button type="button" class="theme-swatch-btn theme-option" data-theme="verde" title="Verde"
            style="background-color: #198754;"></button>
    <button type="button" class="theme-swatch-btn theme-option" data-theme="roxo" title="Roxo"
            style="background-color: #6f42c1;"></button>
    <button type="button" class="theme-swatch-btn theme-option" data-theme="laranja" title="Laranja"
            style="background-color: #e8590c;"></button>
    <button type="button" class="theme-swatch-btn theme-option" data-theme="indigo" title="Índigo"
            style="background-color: #4338ca;"></button>
</div>
