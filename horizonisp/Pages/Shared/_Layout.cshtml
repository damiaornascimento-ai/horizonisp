@{
    var path = Context.Request.Path.Value ?? "/";
    string NavClass(string prefix) =>
        path.Equals(prefix, StringComparison.OrdinalIgnoreCase)
        || path.StartsWith(prefix + "/", StringComparison.OrdinalIgnoreCase)
            ? "mk-nav-link active"
            : "mk-nav-link";
    var pageTitle = ViewData["Title"]?.ToString() ?? "Horizon ISP";
    var userInitial = User.Identity?.Name?.Length > 0
        ? User.Identity.Name[0].ToString().ToUpperInvariant()
        : "?";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Horizon ISP</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/horizonisp.styles.css" asp-append-version="true" />
</head>
<body class="mk-app">
@if (User.Identity?.IsAuthenticated ?? false)
{
    <div class="mk-sidebar-overlay" aria-hidden="true"></div>

    <aside class="mk-sidebar">
        <a class="mk-sidebar-brand" asp-page="/Index">
            <span class="mk-brand-logo" aria-hidden="true">H</span>
            <span>
                <div class="mk-sidebar-brand-title">Horizon ISP</div>
                <div class="mk-sidebar-brand-sub">ERP · Gestão do provedor</div>
            </span>
        </a>

        <nav class="mk-sidebar-nav">
            <div class="mk-nav-section">
                <div class="mk-nav-section-title">Workspace</div>
                <a class="@NavClass("/Index")" asp-page="/Index">
                    <span class="mk-nav-icon"><i class="bi bi-grid-1x2-fill"></i></span>
                    <span>Painel inicial</span>
                </a>
            </div>

            <div class="mk-nav-section">
                <div class="mk-nav-section-title">Comercial</div>
                <a class="@NavClass("/Clientes")" asp-page="/Clientes/Index">
                    <span class="mk-nav-icon"><i class="bi bi-people-fill"></i></span>
                    <span>Clientes</span>
                </a>
                <a class="@NavClass("/Planos")" asp-page="/Planos/Index">
                    <span class="mk-nav-icon"><i class="bi bi-box-seam-fill"></i></span>
                    <span>Planos</span>
                </a>
                <a class="@NavClass("/Assinaturas")" asp-page="/Assinaturas/Index">
                    <span class="mk-nav-icon"><i class="bi bi-wifi"></i></span>
                    <span>Assinaturas</span>
                </a>
            </div>

            <div class="mk-nav-section">
                <div class="mk-nav-section-title">Financeiro</div>
                <a class="@NavClass("/Faturas")" asp-page="/Faturas/Index">
                    <span class="mk-nav-icon"><i class="bi bi-receipt"></i></span>
                    <span>Faturas</span>
                </a>
                <a class="@NavClass("/Faturamento")" asp-page="/Faturamento/Index">
                    <span class="mk-nav-icon"><i class="bi bi-cash-stack"></i></span>
                    <span>Faturamento</span>
                </a>
                <a class="@NavClass("/Nfse")" asp-page="/Nfse/Index">
                    <span class="mk-nav-icon"><i class="bi bi-file-earmark-text"></i></span>
                    <span>NFS-e</span>
                </a>
            </div>

            <div class="mk-nav-section">
                <div class="mk-nav-section-title">Atendimento</div>
                <a class="@NavClass("/Chamados")" asp-page="/Chamados/Index">
                    <span class="mk-nav-icon"><i class="bi bi-headset"></i></span>
                    <span>Atendimentos</span>
                </a>
                <a class="@NavClass("/OrdensServico")" asp-page="/OrdensServico/Index">
                    <span class="mk-nav-icon"><i class="bi bi-tools"></i></span>
                    <span>Ordens de serviço</span>
                </a>
            </div>

            <div class="mk-nav-section">
                <div class="mk-nav-section-title">Técnico</div>
                <a class="@NavClass("/Rede")" asp-page="/Rede/Index">
                    <span class="mk-nav-icon"><i class="bi bi-diagram-3-fill"></i></span>
                    <span>Rede FTTH</span>
                </a>
                <a class="@NavClass("/Clientes/Mapa")" asp-page="/Clientes/Mapa">
                    <span class="mk-nav-icon"><i class="bi bi-geo-alt-fill"></i></span>
                    <span>Mapa de instalações</span>
                </a>
            </div>

            <div class="mk-nav-section">
                <div class="mk-nav-section-title">Sistema</div>
                @if (User.IsInRole("Admin"))
                {
                    <a class="@NavClass("/Usuarios")" asp-page="/Usuarios/Index">
                        <span class="mk-nav-icon"><i class="bi bi-person-badge-fill"></i></span>
                        <span>Usuários</span>
                    </a>
                }
                <a class="@NavClass("/Integracoes")" asp-page="/Integracoes/Index">
                    <span class="mk-nav-icon"><i class="bi bi-plug-fill"></i></span>
                    <span>Integrações</span>
                </a>
                <a class="@NavClass("/Relatorios")" asp-page="/Relatorios/Index">
                    <span class="mk-nav-icon"><i class="bi bi-bar-chart-line-fill"></i></span>
                    <span>Relatórios</span>
                </a>
            </div>
        </nav>

        <div class="mk-sidebar-footer">
            <span class="mk-erp-badge">ERP</span>
            <span class="text-white-50 small">Horizon ISP v1.0</span>
        </div>
    </aside>

    <div class="mk-main">
        <header class="mk-topbar">
            <div class="mk-topbar-accent" aria-hidden="true"></div>
            <div class="mk-topbar-inner">
                <div class="d-flex align-items-center gap-3 flex-grow-1 min-w-0">
                    <button type="button" class="mk-sidebar-toggle" data-mk-sidebar-toggle aria-label="Abrir menu">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="mk-topbar-titles d-none d-md-block">
                        <p class="mk-topbar-breadcrumb">MK ERP / @pageTitle</p>
                        <h2 class="mk-topbar-title">@pageTitle</h2>
                    </div>
                    <partial name="_MkSearchBar" />
                </div>
            <div class="mk-topbar-user">
                <div class="mk-user-pill d-none d-sm-flex">
                        <span class="mk-user-avatar">@userInitial</span>
                        <span class="text-truncate" style="max-width: 140px;">@User.Identity?.Name</span>
                    </div>
                    <a asp-page="/Logout" class="btn btn-mk-ghost btn-sm" title="Sair">
                        <i class="bi bi-box-arrow-right"></i>
                        <span class="d-none d-lg-inline ms-1">Sair</span>
                    </a>
                </div>
            </div>
        </header>

        <main class="mk-content" role="main">
            @RenderBody()
        </main>

        <footer class="mk-footer">
            <span>&copy; @DateTime.Now.Year Horizon ISP ERP</span>
            <span class="text-muted">· Sistema de gestão para provedores de internet</span>
        </footer>
    </div>
}
else
{
    <main class="mk-content container py-4" role="main">
        @RenderBody()
    </main>
}

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
