<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Horizon ISP</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/horizonisp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-page="/Index">Horizon ISP</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Alternar navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto align-items-lg-center">
                        <li class="nav-item py-lg-0 py-2">
                            <a asp-page="/Portal/Login" class="btn btn-success btn-sm fw-semibold btn-area-cliente">
                                Área do Cliente
                            </a>
                        </li>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Index">Painel</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Clientes/Index">Clientes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Planos/Index">Planos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Assinaturas/Index">Assinaturas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Faturas/Index">Faturas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Faturamento/Index">Faturamento</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Nfse/Index">NFS-e</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Chamados/Index">Chamados</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/OrdensServico/Index">O.S.</a>
                            </li>
                            <li class="nav-item dropdown py-lg-0 py-2">
                                <a class="btn btn-danger btn-sm fw-semibold dropdown-toggle btn-nav-administracao"
                                   href="#" id="navAdministracao" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    Administração
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navAdministracao">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-page="/Usuarios/Index">Usuários</a>
                                        </li>
                                    }
                                    <li>
                                        <a class="dropdown-item" asp-page="/Integracoes/Index">Integrações</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-page="/Rede/Index">Rede</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-page="/Relatorios/Index">Relatórios</a>
                                    </li>
                                </ul>
                            </li>
                    }
                    </ul>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <span class="navbar-text text-white-50 me-3">@User.Identity?.Name</span>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-page="/Login" asp-page-handler="Logout" class="d-inline">
                                    <button type="submit" class="btn btn-outline-light btn-sm">Sair</button>
                                </form>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3">
        <div class="container">
            <span>&copy; @DateTime.Now.Year - Horizon ISP - Gestão de provedor de internet</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
