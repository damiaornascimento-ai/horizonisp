<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Horizon ISP</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/horizonisp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-page="/Index">Horizon ISP</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Alternar navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Index">Painel</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Clientes/Index">Clientes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Planos/Index">Planos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Assinaturas/Index">Assinaturas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Faturas/Index">Faturas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Faturamento/Index">Faturamento</a>
                            </li>
                        </ul>
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <span class="navbar-text text-white-50 me-3">@User.Identity?.Name</span>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-page="/Login" asp-page-handler="Logout" class="d-inline">
                                    <button type="submit" class="btn btn-outline-light btn-sm">Sair</button>
                                </form>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3">
        <div class="container d-flex justify-content-between flex-wrap gap-2">
            <span>&copy; @DateTime.Now.Year - Horizon ISP - Gestão de provedor de internet</span>
            <a asp-page="/Portal/Login" class="text-muted">Área do cliente</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
