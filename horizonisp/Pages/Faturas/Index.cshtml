@page
@model horizonisp.Pages.Faturas.IndexModel
@{
    ViewData["Title"] = "Faturas";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h1 class="h3 mb-0">Faturas</h1>
    <div class="btn-group">
        <a asp-page="Index" class="btn btn-sm @(Model.FiltroStatus is null ? "btn-primary" : "btn-outline-primary")">Todas</a>
        <a asp-page="Index" asp-route-status="@StatusFatura.Pendente" class="btn btn-sm @(Model.FiltroStatus == StatusFatura.Pendente ? "btn-primary" : "btn-outline-primary")">Pendentes</a>
        <a asp-page="Index" asp-route-status="@StatusFatura.Atrasada" class="btn btn-sm @(Model.FiltroStatus == StatusFatura.Atrasada ? "btn-primary" : "btn-outline-primary")">Atrasadas</a>
        <a asp-page="Index" asp-route-status="@StatusFatura.Paga" class="btn btn-sm @(Model.FiltroStatus == StatusFatura.Paga ? "btn-primary" : "btn-outline-primary")">Pagas</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Referência</th>
                    <th>Cliente</th>
                    <th>Plano</th>
                    <th>Valor</th>
                    <th>Vencimento</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var fatura in Model.Faturas)
            {
                <tr>
                    <td>@fatura.Referencia</td>
                    <td>@fatura.Assinatura.Cliente.Nome</td>
                    <td>@fatura.Assinatura.Plano.Nome</td>
                    <td>@EnumHelper.Moeda(fatura.Valor)</td>
                    <td>@fatura.DataVencimento.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    <td>@EnumHelper.ObterStatusFatura(fatura.Status)</td>
                    <td class="text-end">
                        @if (fatura.Status is StatusFatura.Pendente or StatusFatura.Atrasada)
                        {
                            <form method="post" asp-page-handler="Pagar" asp-route-id="@fatura.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-success">Marcar paga</button>
                            </form>
                        }
                        else if (fatura.DataPagamento.HasValue)
                        {
                            <span class="text-muted small">Paga em @fatura.DataPagamento.Value.ToLocalTime().ToString("dd/MM/yyyy")</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
