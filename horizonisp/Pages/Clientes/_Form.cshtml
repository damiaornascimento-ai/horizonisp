@model horizonisp.Models.Cliente

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Documento" class="form-label"></label>
        <input asp-for="Documento" class="form-control" />
        <span asp-validation-for="Documento" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Telefone" class="form-label"></label>
        <input asp-for="Telefone" class="form-control" />
        <span asp-validation-for="Telefone" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="Endereco" class="form-label"></label>
        <input asp-for="Endereco" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Cep" class="form-label"></label>
        <input asp-for="Cep" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="Cidade" class="form-label"></label>
        <input asp-for="Cidade" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="Estado" class="form-label"></label>
        <input asp-for="Estado" class="form-control" maxlength="2" />
    </div>
    <div class="col-md-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<StatusCliente>()"></select>
    </div>
</div>

<hr class="my-4" />

<h2 class="h6 text-muted mb-3">Portal do cliente</h2>
<div class="row g-3">
    <div class="col-md-6">
        <label class="form-label">Senha do portal</label>
        <input name="SenhaPortal" type="password" class="form-control" autocomplete="new-password" />
        <div class="form-text">Deixe em branco para manter a senha atual.</div>
    </div>
    <div class="col-md-6 d-flex align-items-end">
        <div class="form-check mb-2">
            <input asp-for="PortalAtivo" class="form-check-input" />
            <label asp-for="PortalAtivo" class="form-check-label">Portal ativo</label>
        </div>
    </div>
</div>
