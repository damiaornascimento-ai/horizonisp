@page
@model horizonisp.Pages.Clientes.CreateModel
@{
    ViewData["Title"] = "Novo cliente";
}

<h1 class="h3 mb-4">Novo cliente</h1>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>
            <partial name="_Form" for="Cliente" />
            <button type="submit" class="btn btn-success">Salvar</button>
            <a asp-page="Index" class="btn btn-danger">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
