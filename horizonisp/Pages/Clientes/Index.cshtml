@page
@model horizonisp.Pages.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<div class="mk-toolbar">
    <h1 class="mk-toolbar-title">Cadastro de clientes</h1>
    <a asp-page="Create" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i>Novo cliente</a>
</div>

@if (TempData["Sucesso"] is string sucesso)
{
    <div class="alert alert-success">@sucesso</div>
}
@if (TempData["Erro"] is string erro)
{
    <div class="alert alert-danger">@erro</div>
}

<form method="get" class="mk-panel mb-4">
    <div class="mk-panel-header"><i class="bi bi-search me-2"></i>Buscar cliente</div>
    <div class="mk-panel-body">
        <div class="row g-3 align-items-end">
            <div class="col-lg-6">
                <label for="busca" class="form-label">Buscar cliente</label>
                <input type="search" id="busca" name="busca" value="@Model.Busca" class="form-control"
                       placeholder="Nome, documento, e-mail, telefone ou cidade" />
            </div>
            <div class="col-lg-6 d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">Buscar</button>
                @if (!string.IsNullOrWhiteSpace(Model.Busca) || Model.Categoria.HasValue)
                {
                    <a asp-page="Index" class="btn btn-outline-secondary">Limpar</a>
                }
            </div>
        </div>
    </div>
</form>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <a asp-page="Index" asp-route-busca="@Model.Busca" asp-route-categoria="@CategoriaConexaoCliente.Online"
           class="text-decoration-none d-block h-100">
            <div class="mk-kpi-card success @(Model.Categoria == CategoriaConexaoCliente.Online ? "border border-success border-2" : "")">
                <div class="mk-kpi-label">Online</div>
                <div class="mk-kpi-value text-success">@Model.TotalOnline</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="Index" asp-route-busca="@Model.Busca" asp-route-categoria="@CategoriaConexaoCliente.Offline"
           class="text-decoration-none d-block h-100">
            <div class="mk-kpi-card warning @(Model.Categoria == CategoriaConexaoCliente.Offline ? "border border-warning border-2" : "")">
                <div class="mk-kpi-label">Offline</div>
                <div class="mk-kpi-value text-warning">@Model.TotalOffline</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="Index" asp-route-busca="@Model.Busca" asp-route-categoria="@CategoriaConexaoCliente.Bloqueado"
           class="text-decoration-none d-block h-100">
            <div class="mk-kpi-card danger @(Model.Categoria == CategoriaConexaoCliente.Bloqueado ? "border border-danger border-2" : "")">
                <div class="mk-kpi-label">Bloqueados</div>
                <div class="mk-kpi-value text-danger">@Model.TotalBloqueados</div>
            </div>
        </a>
    </div>
</div>

<div class="mk-filter-bar">
    <span class="text-muted small fw-semibold align-self-center me-1">Conexão:</span>
    <a asp-page="Index" asp-route-busca="@Model.Busca"
       class="mk-filter-chip @(Model.Categoria is null ? "active" : "")">Todos</a>
    <a asp-page="Index" asp-route-busca="@Model.Busca" asp-route-categoria="@CategoriaConexaoCliente.Online"
       class="mk-filter-chip @(Model.Categoria == CategoriaConexaoCliente.Online ? "active" : "")">Online</a>
    <a asp-page="Index" asp-route-busca="@Model.Busca" asp-route-categoria="@CategoriaConexaoCliente.Offline"
       class="mk-filter-chip @(Model.Categoria == CategoriaConexaoCliente.Offline ? "active" : "")">Offline</a>
    <a asp-page="Index" asp-route-busca="@Model.Busca" asp-route-categoria="@CategoriaConexaoCliente.Bloqueado"
       class="mk-filter-chip @(Model.Categoria == CategoriaConexaoCliente.Bloqueado ? "active" : "")">Bloqueados</a>
</div>

<div class="mk-panel">
    <div class="mk-panel-header">Lista de clientes</div>
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Documento</th>
                    <th>E-mail</th>
                    <th>Telefone</th>
                    <th>Conexão</th>
                    <th>Status</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Clientes)
            {
                var cliente = item.Cliente;
                <tr>
                    <td>@cliente.Nome</td>
                    <td>@cliente.Documento</td>
                    <td>@cliente.Email</td>
                    <td>@cliente.Telefone</td>
                    <td>
                        <span class="badge @EnumHelper.ClasseBadgeCategoriaConexao(item.CategoriaConexao)">
                            @EnumHelper.ObterCategoriaConexaoCliente(item.CategoriaConexao)
                        </span>
                    </td>
                    <td>@EnumHelper.ObterStatusCliente(cliente.Status)</td>
                    <td class="text-end">
                        <div class="d-inline-flex flex-wrap gap-1 justify-content-end">
                            @{
                                var bloqueioModel = new ClienteBloqueioAcoesModel
                                {
                                    ClienteId = cliente.Id,
                                    Status = cliente.Status,
                                    Pagina = "Index",
                                    Busca = Model.Busca,
                                    Categoria = Model.Categoria
                                };
                            }
                            <partial name="_ClienteBloqueioAcoes" model="bloqueioModel" />
                            <a asp-page="Edit" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Clientes.Any())
{
    <p class="text-muted mt-3 mb-0">Nenhum cliente encontrado para os filtros selecionados.</p>
}
