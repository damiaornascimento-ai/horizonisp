@page
@model horizonisp.Pages.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Clientes</h1>
    <a asp-page="Create" class="btn btn-primary">Novo cliente</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Documento</th>
                    <th>E-mail</th>
                    <th>Telefone</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var cliente in Model.Clientes)
            {
                <tr>
                    <td>@cliente.Nome</td>
                    <td>@cliente.Documento</td>
                    <td>@cliente.Email</td>
                    <td>@cliente.Telefone</td>
                    <td>@EnumHelper.ObterStatusCliente(cliente.Status)</td>
                    <td class="text-end">
                        <a asp-page="Edit" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
