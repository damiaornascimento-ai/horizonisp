@page
@model horizonisp.Pages.Clientes.MapaModel
@{
    ViewData["Title"] = "Mapa de instalações";
}

<div class="mk-toolbar">
    <div>
        <h1 class="mk-toolbar-title">Mapa de instalações</h1>
        <p class="text-muted small mb-0">
            @Model.TotalComLocalizacao com localização · @Model.TotalSemLocalizacao pendente(s)
        </p>
    </div>
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-people me-1"></i>Lista de clientes
    </a>
</div>

<div class="mk-panel mb-3">
    <div class="mk-panel-body py-2">
        <span class="text-muted small">
            <i class="bi bi-info-circle me-1"></i>
            Clique em um marcador para abrir a instalação do cliente. Clientes sem posição podem ser marcados na tela de localização.
        </span>
    </div>
</div>

<div id="mapaClientes" class="mk-map mk-map-overview"></div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script src="~/js/cliente-mapa.js" asp-append-version="true"></script>
    <script>
        window.horizonMapaGeral = {
            clientes: @Html.Raw(Model.ClientesJson),
            urlLocalizacao: '@Url.Page("/Clientes/Localizacao", new { id = "__id__" })'
        };
        document.addEventListener('DOMContentLoaded', () => horizonMapa.iniciarGeral(window.horizonMapaGeral));
    </script>
}
