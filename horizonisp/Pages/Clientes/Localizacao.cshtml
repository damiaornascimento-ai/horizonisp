@page "{id:int}"
@using horizonisp.Helpers
@model horizonisp.Pages.Clientes.LocalizacaoModel
@{
    ViewData["Title"] = "Localização da instalação";
    var temLocalizacao = Model.Latitude.HasValue && Model.Longitude.HasValue;
    var cliente = Model.Cliente;
}

<div class="mk-localizacao-page">
<div class="mk-toolbar mk-localizacao-toolbar">
    <div>
        <h1 class="mk-toolbar-title">@cliente.Nome</h1>
        <p class="text-muted small mb-0">
            @cliente.Endereco · @cliente.Cidade/@cliente.Estado
        </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-page="Mapa" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-map me-1"></i>Mapa geral
        </a>
        <a asp-page="Edit" asp-route-id="@cliente.Id" class="btn btn-primary btn-sm">
            <i class="bi bi-person-lines-fill me-1"></i>Cadastro do cliente
        </a>
    </div>
</div>

@if (TempData["Sucesso"] is string sucesso)
{
    <div class="alert alert-success mb-3">@sucesso</div>
}

    <div class="mk-panel mk-cliente-resumo mb-3 mk-localizacao-header">
        <div class="mk-panel-header d-flex flex-wrap align-items-center justify-content-between gap-2">
            <span><i class="bi bi-person-badge me-1"></i>Dados do cliente</span>
            <a asp-page="Edit" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-pencil-square me-1"></i>Editar cadastro
            </a>
        </div>
        <div class="mk-panel-body">
            <div class="row g-3 small">
                <div class="col-6 col-md-3">
                    <div class="text-muted">Status</div>
                    <span class="badge @EnumHelper.ClasseBadgeStatusCliente(cliente.Status)">
                        @EnumHelper.ObterStatusCliente(cliente.Status)
                    </span>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted">Telefone</div>
                    <div class="fw-semibold">@cliente.Telefone</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted">E-mail</div>
                    <div class="fw-semibold text-break">@cliente.Email</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted">Documento</div>
                    <div class="fw-semibold">@cliente.Documento</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted">Portal do cliente</div>
                    <span class="badge @(cliente.PortalAtivo ? "bg-success" : "bg-secondary")">
                        @(cliente.PortalAtivo ? "Ativo" : "Inativo")
                    </span>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted">Instalação no mapa</div>
                    <span class="badge @(temLocalizacao ? "bg-success" : "bg-warning text-dark")">
                        @(temLocalizacao ? "Marcada" : "Pendente")
                    </span>
                    @if (cliente.LocalizacaoInstalacaoEm.HasValue)
                    {
                        <div class="text-muted mt-1" style="font-size: 0.75rem;">
                            @cliente.LocalizacaoInstalacaoEm.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </div>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.PlanoAtivo))
                {
                    <div class="col-6 col-md-3">
                        <div class="text-muted">Plano ativo</div>
                        <div class="fw-semibold">@Model.PlanoAtivo</div>
                    </div>
                }
                @if (Model.StatusAssinaturaAtiva.HasValue)
                {
                    <div class="col-6 col-md-3">
                        <div class="text-muted">Assinatura</div>
                        <div class="fw-semibold">@EnumHelper.ObterStatusAssinatura(Model.StatusAssinaturaAtiva.Value)</div>
                    </div>
                }
                <div class="col-6 col-md-3">
                    <div class="text-muted">Sinal da ONU</div>
                    @if (Model.OnuSinalDbm.HasValue)
                    {
                        <span class="badge @EnumHelper.ClasseBadgeSinalOnu(Model.OnuSinalDbm)">
                            @EnumHelper.FormatarSinalOnu(Model.OnuSinalDbm)
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Sem leitura</span>
                    }
                    @if (Model.OnuStatus.HasValue)
                    {
                        <div class="mt-1">
                            <span class="badge @EnumHelper.ClasseBadgeStatusOnu(Model.OnuStatus.Value)">
                                ONU @EnumHelper.ObterStatusOnu(Model.OnuStatus.Value)
                            </span>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.OnuSerial))
                    {
                        <div class="text-muted mt-1" style="font-size: 0.75rem;">Serial @Model.OnuSerial</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mk-panel mb-3 mk-localizacao-header">
        <div class="mk-panel-body py-2 small text-muted mb-0">
            <i class="bi bi-layers me-1"></i>Use o seletor <strong>Camadas</strong> no mapa para alternar entre rua, satélite e terreno.
            <span class="mx-2">·</span>
            <strong>GPS:</strong> aguarde a precisão melhorar ao ar livre.
            <span class="mx-2">·</span>
            <strong>Manual:</strong> clique no mapa ou arraste o marcador.
        </div>
    </div>

    <form method="post" asp-route-id="@cliente.Id" id="formLocalizacao" class="mk-localizacao-form">
        <input type="hidden" name="Latitude" id="inputLatitude" value="@(Model.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")" />
        <input type="hidden" name="Longitude" id="inputLongitude" value="@(Model.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

        <div class="d-flex flex-wrap gap-2 mb-2 mk-localizacao-controls">
            <button type="button" class="btn btn-primary btn-sm" id="btnGps">
                <i class="bi bi-geo-alt-fill me-1"></i>Usar minha localização (GPS)
            </button>
            <button type="button" class="btn btn-outline-primary btn-sm" id="btnManual">
                <i class="bi bi-hand-index me-1"></i>Marcar manualmente no mapa
            </button>
            @if (temLocalizacao)
            {
                <button type="submit" asp-page-handler="Remover" class="btn btn-outline-danger btn-sm ms-auto"
                        onclick="return confirm('Remover a localização deste cliente?');">
                    Remover marcação
                </button>
            }
        </div>

        <p id="mapaStatus" class="small text-muted mb-1">@(temLocalizacao ? "Arraste o marcador ou clique no mapa para ajustar." : "Nenhuma posição definida.")</p>
        <p id="mapaCoordenadas" class="small fw-semibold mb-2"></p>

        <div class="mk-localizacao-map-wrap">
            <div id="mapaInstalacao" class="mk-map"></div>
        </div>

        <div class="mk-localizacao-actions">
            <button type="submit" class="btn btn-success">
                <i class="bi bi-check-lg me-1"></i>Salvar localização
            </button>
            <a asp-page="Index" class="btn btn-danger">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script src="~/js/cliente-mapa.js" asp-append-version="true"></script>
    <script>
        window.horizonMapaCliente = {
            latitude: @(Model.Latitude.HasValue ? Model.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null"),
            longitude: @(Model.Longitude.HasValue ? Model.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null"),
            endereco: @Html.Raw(System.Text.Json.JsonSerializer.Serialize($"{cliente.Endereco}, {cliente.Cidade} - {cliente.Estado}"))
        };
        document.addEventListener('DOMContentLoaded', () => horizonMapa.iniciarCliente(window.horizonMapaCliente));
    </script>
}
