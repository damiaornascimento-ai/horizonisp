@page "{id:int}"
@model horizonisp.Pages.Clientes.EditModel
@{
    ViewData["Title"] = "Editar cliente";
}

<h1 class="h3 mb-4">Editar cliente</h1>

@if (TempData["Sucesso"] is string sucesso)
{
    <div class="alert alert-success">@sucesso</div>
}
@if (TempData["Erro"] is string erro)
{
    <div class="alert alert-danger">@erro</div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-2">
        <div>
            <div class="text-muted small">Controle de acesso</div>
            <div class="fw-semibold">@EnumHelper.ObterStatusCliente(Model.Cliente.Status)</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            @{
                var bloqueioModel = new ClienteBloqueioAcoesModel
                {
                    ClienteId = Model.Cliente.Id,
                    Status = Model.Cliente.Status,
                    Pagina = "Edit"
                };
            }
            <partial name="_ClienteBloqueioAcoes" model="bloqueioModel" />
            <a asp-page="Localizacao" asp-route-id="@Model.Cliente.Id" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-geo-alt me-1"></i>Localização da instalação
            </a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="post" novalidate>
            <input type="hidden" asp-for="Cliente.Id" />
            <input type="hidden" asp-for="Cliente.DataCadastro" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>
            <partial name="_Form" for="Cliente" />
            <button type="submit" class="btn btn-success">Salvar</button>
            <a asp-page="Index" class="btn btn-danger">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/cliente-form.js" asp-append-version="true"></script>
}
