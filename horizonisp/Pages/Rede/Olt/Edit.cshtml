@page "{id:int}"
@model horizonisp.Pages.Rede.Olt.EditModel
@{ ViewData["Title"] = "Editar OLT"; }
<h1 class="h3 mb-4">Editar OLT</h1>
<div class="card border-0 shadow-sm"><div class="card-body">
<form method="post">
    <input type="hidden" asp-for="Olt.Id" />
    <partial name="_Form" model="Model.Olt" />
    <button type="submit" class="btn btn-success">Salvar</button>
    <a asp-page="/Rede/Index" class="btn btn-danger">Cancelar</a>
</form>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
