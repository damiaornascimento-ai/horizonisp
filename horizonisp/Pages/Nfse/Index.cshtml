@page
@model horizonisp.Pages.Nfse.IndexModel
@{
    ViewData["Title"] = "NFS-e";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h1 class="h3 mb-0">NFS-e</h1>
    <div class="btn-group">
        <a asp-page="Index" class="btn btn-sm @(Model.FiltroStatus is null ? "btn-primary" : "btn-outline-primary")">Todas</a>
        <a asp-page="Index" asp-route-status="@StatusNfse.Autorizada" class="btn btn-sm @(Model.FiltroStatus == StatusNfse.Autorizada ? "btn-primary" : "btn-outline-primary")">Autorizadas</a>
        <a asp-page="Index" asp-route-status="@StatusNfse.Rejeitada" class="btn btn-sm @(Model.FiltroStatus == StatusNfse.Rejeitada ? "btn-primary" : "btn-outline-primary")">Rejeitadas</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Número</th>
                    <th>Cliente</th>
                    <th>Fatura</th>
                    <th>Valor</th>
                    <th>Status</th>
                    <th>Emissão</th>
                    <th>Verificação</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var nota in Model.Notas)
            {
                <tr>
                    <td>@nota.Numero</td>
                    <td>@nota.Fatura.Assinatura.Cliente.Nome</td>
                    <td>@nota.Fatura.Referencia</td>
                    <td>@EnumHelper.Moeda(nota.Valor)</td>
                    <td>@EnumHelper.ObterStatusNfse(nota.Status)</td>
                    <td>@(nota.DataEmissao?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                    <td class="font-monospace small">@nota.CodigoVerificacao</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Notas.Any())
{
    <p class="text-muted mt-3">Nenhuma NFS-e emitida ainda. Notas são geradas quando uma fatura é paga.</p>
}
