@page
@model horizonisp.Pages.Portal.Chamados.CreateModel
@{
    ViewData["Title"] = "Abrir chamado";
}

<h1 class="h3 mb-4">Abrir chamado</h1>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Input.Assunto" class="form-label"></label>
                <input asp-for="Input.Assunto" class="form-control" />
                <span asp-validation-for="Input.Assunto" class="text-danger"></span>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Input.Categoria" class="form-label"></label>
                    <select asp-for="Input.Categoria" class="form-select" asp-items="Html.GetEnumSelectList<CategoriaChamado>()"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Prioridade" class="form-label"></label>
                    <select asp-for="Input.Prioridade" class="form-select" asp-items="Html.GetEnumSelectList<PrioridadeChamado>()"></select>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Mensagem" class="form-label"></label>
                <textarea asp-for="Input.Mensagem" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Input.Mensagem" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-dark">Enviar</button>
            <a asp-page="Index" class="btn btn-link">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
