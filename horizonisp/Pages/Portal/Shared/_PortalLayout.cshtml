<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Área do Cliente</title>
    <partial name="_ThemeHead" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
            <div class="container">
                <a class="navbar-brand" asp-page="/Portal/Index">Horizon ISP</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#portalNav"
                        aria-controls="portalNav" aria-expanded="false" aria-label="Alternar navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="portalNav">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Portal/Index">Início</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Portal/Faturas/Index">Minhas faturas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Portal/Conta/Senha">Minha conta</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Portal/Chamados/Index">Suporte</a>
                            </li>
                        </ul>
                        <div class="d-flex align-items-center gap-2 gap-lg-3">
                            <partial name="_ThemePicker" />
                            <span class="navbar-text text-white-50">@User.Identity?.Name</span>
                            <a asp-page="/Logout" class="btn btn-outline-light btn-sm">Sair</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container pb-4">
        @RenderBody()
    </div>

    <footer class="border-top py-3 mt-auto">
        <div class="container text-muted small">
            Precisa de ajuda? Entre em contato com o suporte do provedor.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
