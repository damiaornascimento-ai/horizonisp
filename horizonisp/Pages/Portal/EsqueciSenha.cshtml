@page
@model horizonisp.Pages.Portal.EsqueciSenhaModel
@{
    ViewData["Title"] = "Esqueci minha senha";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Área do Cliente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">
    <div class="login-page-form" style="min-height: 100vh;">
        <div class="card">
            <div class="card-body">
                <div class="text-center mb-4">
                    <div class="mk-sidebar-brand-title text-primary fs-5 fw-bold">Horizon ISP</div>
                    <h1 class="h5 mt-2 mb-1">Esqueci minha senha</h1>
                    <p class="text-muted small mb-0">
                        Informe o e-mail ou CPF/CNPJ cadastrado.
                    </p>
                </div>

                        @if (Model.Enviado)
                        {
                            <div class="alert alert-success">
                                Se existir uma conta ativa com esses dados, você receberá um e-mail com o link para criar uma nova senha.
                            </div>
                        }
                        else
                        {
                            <form method="post">
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                                <div class="mb-3">
                                    <label asp-for="Input.Identificador" class="form-label"></label>
                                    <input asp-for="Input.Identificador" class="form-control" autocomplete="username" />
                                    <span asp-validation-for="Input.Identificador" class="text-danger"></span>
                                </div>
                                <button type="submit" class="btn btn-primary w-100 mb-3">Enviar link de recuperação</button>
                            </form>
                        }

                        <a asp-page="/Login" class="small">Voltar ao login</a>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
