@page
@model horizonisp.Pages.Portal.LoginModel
@{
    ViewData["Title"] = "Entrar";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Área do Cliente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="container">
        <div class="row justify-content-center align-items-center min-vh-100">
            <div class="col-md-5">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h1 class="h4 mb-1">Área do Cliente</h1>
                        <p class="text-muted mb-4">Consulte faturas e gerencie sua conexão.</p>

                        @if (!string.IsNullOrEmpty(Model.Erro))
                        {
                            <div class="alert alert-danger">@Model.Erro</div>
                        }

                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <div class="mb-3">
                                <label asp-for="Input.Identificador" class="form-label"></label>
                                <input asp-for="Input.Identificador" class="form-control" autocomplete="username" />
                                <span asp-validation-for="Input.Identificador" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Input.Senha" class="form-label"></label>
                                <input asp-for="Input.Senha" class="form-control" autocomplete="current-password" />
                                <span asp-validation-for="Input.Senha" class="text-danger"></span>
                            </div>
                            <button type="submit" class="btn btn-dark w-100">Entrar</button>
                        </form>

                        <p class="text-muted small mt-4 mb-0">
                            Demo: joao.silva@email.com / cliente123
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
